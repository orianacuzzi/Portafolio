      "source": [
        "query_cohort_retention_final = '''\n",
        "WITH cohortes AS (\n",
        "    SELECT\n",
        "        id_usuario,\n",
        "        DATE_TRUNC('month', CAST(fecha_registro AS DATE)) AS cohorte_mes,\n",
        "        CAST(fecha_registro AS DATE) AS fecha_registro\n",
        "    FROM users\n",
        "),\n",
        "\n",
        "retencion AS (\n",
        "    SELECT\n",
        "        c.cohorte_mes,\n",
        "        c.id_usuario,\n",
        "        ua.dias_despues_registro\n",
        "    FROM cohortes c\n",
        "    JOIN user_activity ua\n",
        "        ON c.id_usuario = ua.id_usuario\n",
        "    WHERE ua.activo = 1\n",
        ")\n",
        "\n",
        "SELECT\n",
        "    cohorte_mes,\n",
        "    COUNT(DISTINCT id_usuario) AS usuarios_iniciales,\n",
        "\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN dias_despues_registro BETWEEN 7 AND 13\n",
        "        THEN id_usuario\n",
        "    END) AS retenido_w1,\n",
        "\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN dias_despues_registro BETWEEN 14 AND 20\n",
        "        THEN id_usuario\n",
        "    END) AS retenido_w2,\n",
        "\n",
        "    COUNT(DISTINCT CASE\n",
        "        WHEN dias_despues_registro BETWEEN 21 AND 27\n",
        "        THEN id_usuario\n",
        "    END) AS retenido_w3,\n",
        "\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN dias_despues_registro BETWEEN 7 AND 13\n",
        "            THEN id_usuario\n",
        "        END)::NUMERIC\n",
        "        / COUNT(DISTINCT id_usuario),\n",
        "        4\n",
        "    ) AS semana_1,\n",
        "\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN dias_despues_registro BETWEEN 14 AND 20\n",
        "            THEN id_usuario\n",
        "        END)::NUMERIC\n",
        "        / COUNT(DISTINCT id_usuario),\n",
        "        4\n",
        "    ) AS semana_2,\n",
        "\n",
        "    ROUND(\n",
        "        COUNT(DISTINCT CASE\n",
        "            WHEN dias_despues_registro BETWEEN 21 AND 27\n",
        "            THEN id_usuario\n",
        "        END)::NUMERIC\n",
        "        / COUNT(DISTINCT id_usuario),\n",
        "        4\n",
        "    ) AS semana_3\n",
        "\n",
        "FROM retencion\n",
        "GROUP BY cohorte_mes\n",
        "ORDER BY cohorte_mes;\n",
        "'''\n",
        "\n",
        "# Ejecutar la consulta\n",
        "cohorte_final = pd.read_sql(query_cohort_retention_final, con=engine)\n",
        "cohorte_final"
      ]
    },
