        "query_conversion = '''\n",
        "\n",
        "SELECT\n",
        "\n",
        "nombre_evento,\n",
        "\n",
        "COUNT(DISTINCT id_usuario) AS usuarios\n",
        "\n",
        "FROM events\n",
        "\n",
        "GROUP BY nombre_evento\n",
        "\n",
        "ORDER BY\n",
        "\n",
        "CASE\n",
        "\n",
        "WHEN nombre_evento='first_visit' THEN 1\n",
        "WHEN nombre_evento='select_item' THEN 2\n",
        "WHEN nombre_evento='add_to_cart' THEN 3\n",
        "WHEN nombre_evento='begin_checkout' THEN 4\n",
        "WHEN nombre_evento='add_payment_info' THEN 5\n",
        "WHEN nombre_evento='purchase' THEN 6\n",
        "\n",
        "END\n",
        "\n",
        "'''\n",
        "\n",
        "conversion = pd.read_sql(\n",
        "query_conversion,\n",
        "con=engine\n",
        ")\n",
        "\n",
        "# Calcular conversión\n",
        "conversion['tasa_conversion'] = (\n",
        "    conversion['usuarios']\n",
        "    .shift(-1)\n",
        "    /\n",
        "    conversion['usuarios']\n",
        "    * 100\n",
        ")\n",
        "\n",
        "# Redondear\n",
        "conversion['tasa_conversion'] = (\n",
        "    conversion['tasa_conversion']\n",
        "    .round(2)\n",
        ")\n",
        "\n",
        "# Reemplazar NaN del último paso\n",
        "conversion['tasa_conversion'] = (\n",
        "    conversion['tasa_conversion']\n",
        "    .fillna('-')\n",
        ")\n",
        "\n",
        "# Mostrar resultado\n",
        "conversion"
      ]
